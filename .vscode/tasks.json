    {
      "label": "② 构建 (Build → dist/cli.js)",
      "type": "shell",
      "command": "node scripts/build.mjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "③ 类型检查 (tsc --noEmit)",
      "type": "shell",
      "command": "npx tsc --noEmit",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "④ 运行构建结果 (node dist/cli.js)",
      "type": "shell",
      "command": "node dist/cli.js",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "⑤ 安装到全局 claude",
      "type": "shell",
      "command": "CLAUDE_GLOBAL=$(npm root -g)/@anthropic-ai/claude-code && cp dist/cli.js \"$CLAUDE_GLOBAL/cli.js\" && echo \"✅ 已覆盖 $CLAUDE_GLOBAL/cli.js\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": [],
      "detail": "将 dist/cli.js 覆盖到全局 @anthropic-ai/claude-code 包（需先完成 Build）"
    },
    {
      "label": "⑥ 构建 + 安装到全局 (一键)",
      "dependsOn": ["② 构建 (Build → dist/cli.js)"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "CLAUDE_GLOBAL=$(npm root -g)/@anthropic-ai/claude-code && cp dist/cli.js \"$CLAUDE_GLOBAL/cli.js\" && echo \"✅ 构建完成，已覆盖全局 claude\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
